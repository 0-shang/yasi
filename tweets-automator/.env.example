# Gemini API Key (Get a free key from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek API Key (Get key from https://platform.deepseek.com/)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# AI Provider Selection
# AI_PROVIDER: 'deepseek' or 'gemini'. If left blank, it auto-detects based on keys filled in.
AI_PROVIDER=

# Twitter/X API Credentials (Get from https://developer.twitter.com/)
# IMPORTANT: In your Twitter Developer App, go to "User authentication settings" 
# and set App Permissions to "Read and Write" BEFORE generating your Access Token and Secret.
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_SECRET=your_twitter_access_secret_here

# Path settings
# WORKSPACE_PATH: Path to your markdown ideas/clippings directory. Defaults to the parent folder.
WORKSPACE_PATH=../
# TWEETS_DIR: Folder where tweets will be drafted, approved, and published.
TWEETS_DIR=../tweets/

# Telegram Bot Credentials
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_USER_ID=your_telegram_user_id_here

# GitHub Personal Access Token (for syncing to ai-nav repo)
GITHUB_PAT=your_github_pat_here

# RSS Feed URL for generating daily hot tweets
RSS_FEED_URL=https://news.ycombinator.com/rss
